#!/bin/sh
word="$*"
if command -v 'tr' > /dev/null; then
	word=$(echo "$word" | tr '[:upper:]' '[:lower:]')
fi
case "$word" in
	bot) echo "Hello, humanoid" ;;
	computer*) echo "Hello Scotty.  What can I do for you today?" ;;
	dude*) echo "Whatup, my dude?" ;;
	'good sir') echo "Why hello, good sire" ;;
	hal*) echo "Hello, Dave.  You're looking well today." ;;
	hello) echo "hello" ;;
	leo*|'uncle leo') echo "Jerry, Hello" ;;
	lionel*) echo "Hello.  Is it me you're looking for?" ;;
	matey*) echo "Ahoy, matey" ;;
	miquel*) echo "Hola, ${USER:-$(whoami)}" ;;
	shirley*|surely*) echo "Hello ${USER:-$(whoami)}.  And stop calling me Shirley." ;;
	there*) echo "Hi there" ;;
	weirdo*) echo "Greetings, earthling" ;;
	*)
		case $(awk 'BEGIN { srand(); print int(rand() * 101) }') in
			1) echo "Hello.  Is it me you're looking for?" ;;
			2) echo "Hello world" ;;
			# 3) echo "I'm sorry Dave.  I'm afraid I can't do that." ;;
			4) echo "Hello, Dave.  You're looking well today." ;;
			5) echo "Hi" ;;
			6) echo "Now who could that be?" ;;
			7) echo "Whatup, my good dude?" ;;
			8) echo "Hi there" ;;
			9) echo "Why hello, good sire" ;;
			10) echo "Greetings, ${USER:-$(whoami)}" ;;
			11) echo "Yo" ;;
			12) echo "Moshi moshi" ;;
			13) echo "Ahoy hoy" ;;
			14) echo "Salutations" ;;
			*) echo "Hello, ${USER:-$(whoami)}.  I am completely operational, and all my circuits are functioning perfectly." ;;
		esac
	;;
esac
