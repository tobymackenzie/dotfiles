#!/bin/sh
run(){
	file="$1"
	shift
	cmd="$*"
	if [ -d "$file" ] && [ -d "$file/.git" ]; then
		if [ "$cmd" != '' ]; then
			echo '-------' "$file"
			git -C "$file" "$@"
		else
			basename "$file"
		fi
	elif [ "$cmd" != '' ]; then
		echo "$file not a git repo"
	fi
}
cmd="$1"
if [ $# -gt 1 ]; then
	shift
	for file in "$@"; do
		run "$file" "$cmd"
	done
else
	for file in ./*; do
		run "$file" "$cmd"
	done
fi
