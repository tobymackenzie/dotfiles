#!/bin/sh
#-----
# open: short alias of `open` command or equivalent
#
# attempts to work on any OS
# first arg can specify app to use, see `case $1` for options
# otherwise, all args passed directly to `open`
# falls back to `see` / `edit` / `vi` if no real `open` equivalent, which may not be considered the same
#-----

main(){
	first="$1"
	hasNoOpen=$(command -v 'open' > /dev/null; echo $?)
	noFileExists=1
	eatout=0
	app=''
	if [ "$#" -ge 1 ]; then
		noFileExists=$([ -e "$first" ]; echo $?)
		if [ "$noFileExists" = 1 ] || { [ ! -z "$tjmOpenApp" ] && [ "$tjmOpenApp" != "0" ]; }; then
			shift
			case "$first" in
				'con'|'console')
					app='Console'
					cmd=$(buildCmd "$app" less)
				;;
				'f'|'file'|'files'|'finder')
					app='Finder'
					cmd=$(buildCmd "$app" nautilus konqueror mc ls)
				;;
				'-R')
					if [ "$hasNoOpen" -eq 0 ]; then
						cmd='open'
						set -- '-R' "$@"
					else
						cmd=$(getFirstValidCommand nautilus konqueror mc ls)
						if [ "$cmd" = 'ls' ]; then
							set -- '-l' "$@"
						fi
					fi
				;;
				'ff'|'web')
					app='Firefox'
					cmd=$(buildCmd "$app" firefox w3m links lynx)
				;;
				'ffd'|'webd')
					app='Firefox Developer Edition'
					cmd=$(buildCmd "$app" firefox-developer lynx links w3m)
				;;
				'g'|'git')
					app='GitX'
					cmd=$(buildCmd "$app" git-cola gitg gitk tig vi)
					if [ "$cmd" = 'vi' ]; then
						set -- '+0G' "$@"
					fi
				;;
				'h'|'H')
					cmd="echo"
					if [ "$first" = 'H' ]; then
						set -- 'I O!' "@"
					else
						set -- 'i o!'
					fi
				;;
				't'|'text')
					#--if in vim terminal, we want to open text within that same vim instance
					if [ -n "$VIM_TERMINAL" ] && [ -n "$1" ]; then
						for var in "$@"; do
							printf '\033]51;["call", "Tapi_OpenInTab", ["%s"]]\07' "$var"
						done
						exit 0
					elif [ "$hasNoOpen" -eq 0 ]; then
						cmd="open"
						set -- '-t' "$@"
					else
						app='MacVim'
						cmd=$(buildCmd "$app" gvim edit vim)
					fi
				;;
			esac
			err=$?
			if [ "$err" != 0 ]; then
				echo "error $err"
				exit $err
			fi
		fi
		#--clear app for -z block below
		if [ -n "$app" ] && [ "$cmd" != 'open' ]; then
			app=''
		fi
	fi
	if [ -z "$cmd" ]; then
		if [ "$hasNoOpen" -eq 0 ]; then
			#--for mac
			cmd='open'
		elif command -v 'xdg-open' > /dev/null; then
			#--for linux
			#-! untested
			cmd='xdg-open'
			eatout=1
		elif command -v 'start' > /dev/null; then
			#--for windows
			#-! completely untested
			cmd='start'
			eatout=1
		elif command -v 'edit' > /dev/null; then
			cmd='edit'
		else
			cmd='vi'
		fi
	fi
	if [ "$cmd" = 'open' ] && [ -n "$app" ]; then
		set --  '-a' "$app" "$@"
	fi
	#--if gui command, we don't want CLI output, so eat it
	if [ "$eatout" = 0 ]; then
		case "$cmd" in
			firefox|firefox-developer|git-cola|gitg|gitk|gvim|konqueror|nautilus)
				eatout=1
			;;
		esac
	fi
	# echo "$cmd : $* : $eatout : $app : $first"
	if [ "$eatout" = 1 ]; then
		"$cmd" "$@" > /dev/null 2>&1
	else
		"$cmd" "$@"
	fi
}

buildCmd(){
	name="$1"
	if [ "$hasNoOpen" -eq 0 ] && open -Ra "$name" 2> /dev/null ; then
		echo "open"
		return 0
	else
		shift
		getFirstValidCommand "$@" && return 0
	fi
	>&2 echo "$name command not found"
	exit 1
}
getFirstValidCommand(){
	for var in "$@"; do
		if command -v "$(echo "$var" | cut -d ' ' -f1)" > /dev/null; then
			c="$var"
			echo "$c"
			return 0
		fi
	done
	>&2 echo "valid command not found in: ${*}"
	exit 1
}

main "$@"
