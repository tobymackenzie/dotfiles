printf '%s ' '👻'
awk 'BEGIN {
	srand();
	n = 1 + int(rand() * 20);
	s="";
	for (i = 1; i <= n; i++){
		s = s"a";
	}
	n = 2 + int(rand() * 22);
	for (i = 1; i <= n; i++){
		s = s"h";
	}
	print s;
}'
printf "\n"
