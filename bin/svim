#!/bin/sh
#-# vim with no swap file, no viminfo, no plugins (third party code)
#-@ ideas from https://vi.stackexchange.com/questions/6177/the-simplest-way-to-start-vim-in-private-mode
if [ -s /dev/stdin ]; then
	addDash=1
	for opt in "$@"; do
		if [ "$opt" = '-' ]; then
			addDash=0
		fi
	done
else
	addDash=0
fi
#-# need to use `set` because couldn't get opts processing correctly otherwise
set -- '-i' 'NONE' '-n' '--noplugin' '-c' "setlocal nobackup nomodeline noshelltemp noswapfile noundofile nowritebackup secure viminfo=\"\"" "$@"
if [ "$addDash" = 1 ]; then
	vim "$@" -
else
	vim "$@"
fi

