#!/bin/sh -i
# ensure aliases are expanded if `sh` is `bash`
# shellcheck disable=SC3040
(set -o posix 2> /dev/null) && set -o posix
if [ $# -lt 1 ]; then
	echo 'Usage: a "command" paths' >&2
	exit 1
fi
cmd="$1"
shift
if [ $# -gt 0 ]; then
	files=("$@")
else
	files=(*)
fi
for file in "${files[@]}"; do
	if [ -d "$file" ]; then
		echo '-------' "$file"
		if cd "$file"; then
			eval "$cmd"
			cd - > /dev/null 2>&1 || exit 1
		else
			echo "Error: no such directory"
			continue
		fi
	fi
done
