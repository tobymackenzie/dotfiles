#!/bin/sh
#=====
# general grouping command for running OS level commands without needing to know which OS / window manager is being run
#=====

#==handle args
if [ -z "$1" ]; then
	cmd='version'
else
	cmd="$1"
fi
if [ $# -gt 0 ]; then
	shift
fi

#==helpers
die(){
	>&2 echo "I'm sorry Dave.  I'm afraid I can't do that. $*"
	exit 1
}
goodbye(){
	echo 'Goodbye'
	sleep 3
}
runPkg(){
	cmd=""
	sub="$1"
	shift

	#--find installed package manager command
	# debian mac fedora fedora arch bsd mac fedora
	#-# pkcon last because it seems to not find some packages, other problems
	for val in pkg apt brew dnf yum pacman port pkcon; do
		if hash "$val" 2> /dev/null; then
			cmd="$val"
			break
		fi
	done
	if [ -z "$cmd" ]; then
		die "don't know how to update"
	fi

	#--normalize subcommand
	if [ "$sub" = 'up' ] || [ "$sub" = 'update' ] || [ "$sub" = 'upgrade' ]; then
		case "$cmd" in
			'apt'|'pkcon')
				sub='update'
			;;
			'brew'|'dnf'|'pkg'|'port'|'yum')
				sub='upgrade'
			;;
			'pacman')
				sub='-Syu'
			;;
		esac
		if [ "$cmd" = 'brew' ] && [ -z "$*" ]; then
			set -- "$@" '--greedy'
		fi
	elif [ "$sub" = 'delete' ] || [ "$sub" = 'remove' ] || [ "$sub" = 'uninstall' ]; then
		case "$cmd" in
			'apt'|'dnf'|'yum')
				sub='remove'
			;;
			'brew')
				sub='uninstall'
			;;
			'pkg')
				sub='delete'
			;;
		esac
	elif [ "$sub" = 'get-details' ] || [ "$sub" = 'info' ] || [ "$sub" = 'show' ]; then
		case "$cmd" in
			'apt')
				sub='show'
			;;
			'pkcon')
				sub='get-details'
			;;
			*)
				sub='info'
			;;
		esac
	elif [ "$sub" = 'add' ] || [ "$sub" = 'install' ]; then
		case "$cmd" in
			'pkg')
				sub='add'
			;;
			*)
				sub='install'
			;;
		esac
	elif [ "$sub" = 'list' ]; then
		#--default to list of installed
		case $cmd in
			'apt')
				if [ -z "$*" ]; then
					set -- "$@" '--installed'
				fi
			;;
			'pkg')
				sub='list-installed'
			;;
		esac
	fi

	#--check permissions to run command
	#---homebrew must be owned by us to modify
	if [ "$cmd" = 'brew' ] && [ "$(stat -f '%Su' "$(which brew)")" != "$(whoami)" ] && { [ "$sub" = 'install' ] || [ "$sub" = 'uninstall' ] || [ "$sub" = 'upgrade' ]; }; then
		die "don't have permissions to run brew command"
	fi
	#---some must run as root
	if [ "$(id -u)" -ne 0 ] && [ "$cmd" != 'brew' ] && [ "$cmd" != 'pkg' ] && { [ "$sub" = 'add' ] || [ "$sub" = 'delete' ] || [ "$sub" = 'install' ] || [ "$sub" = 'remove' ] || [ "$sub" = '-Syu' ] || [ "$sub" = 'update' ] || [ "$sub" = 'upgrade' ]; }; then
		set -- "$cmd" "$@"
		cmd="sudo"
	fi

	#--run
	set -- "$sub" "$@"
	$cmd "$@"
}

#==main
case "$cmd" in
	'down'|'off'|'poweroff'|'shutdown') #: shut down computer / OS
		if command -v 'shutdown' > /dev/null; then
			if [ -z "$*" ]; then
				set -- 'now'
			fi
			goodbye
			shutdown "$@"
		else
			die "don't know how to shutdown"
		fi
	;;
	'-h'|'h'|'help') #: show help for this command
		echo "Usage: os <subcommand> [options]"
		echo "os command must be run with one of the following subcommands"
		grep -o "'.*)\(\s*#.*\)\$" "$TJM_DOTFILES_PATH/bin/os" | # grab formatted lines
			sed "s/'//g" | # strip quotes for terseness
			sed 's/^\(.*\))[ ]*#:/\1:/g' | # nicer formatting
			GREP_COLOR='01;32' grep --color '^.*:' # color subcommands
	;;
	'halt') #: halt computer / OS
		if command -v 'halt' > /dev/null; then
			goodbye
			halt "$@"
		else
			die "don't know how to halt"
		fi
	;;
	'hibernate'|'sleep'|'suspend') #: hibernate computer / OS
		#--mac
		if command -v 'pmset' > /dev/null; then
			goodbye
			set -- 'sleepnow' "$@"
			pmset "$@"
		else
			die "don't know how to sleep"
		fi
	;;
	'in'|'install') #: install OS package
		set -- 'install' "$@"
		runPkg "$@"
	;;
	'i'|'info'|'-v'|'v'|'version') #: get OS info, or package info with arg(s)
		if [ -z "$*" ]; then
			uptime="$(uptime)"
			case "$TJM_OS" in
				linux)
					if [ -r '/etc/os-release' ]; then
						. /etc/os-release
						if [ -n "$PRETTY_NAME" ]; then
							echo "$PRETTY_NAME"
						else
							echo "$NAME $VERSION"
						fi
					fi
					# free -h
					top="$(top -b -n 1 | head -5)"
					cpu="$(grep 'model name' /proc/cpuinfo | head -1 | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					cpuUsage="$(echo "$top" | grep '%Cpu' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					load="$(echo "$uptime" | sed 's/^.*average: //')"
					procs="$(echo "$top" | grep 'Tasks \?:' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					mem="$(echo "$top" | grep 'Mem \?:' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					swap="$(echo "$top" | grep 'Swap \?:' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
				;;
				darwin)
					top="$(top -l 1 -n 0 -s 0)"
					hi="$(hostinfo)"
					cpu="$(sysctl -n machdep.cpu.brand_string)"
					cpuUsage="$(echo "$top" | grep 'CPU usage' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					load="$(echo "$top" | grep 'Load ' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					mem="$(echo "$hi" | grep 'Primary mem' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					memUsed="$(echo "$top" | grep PhysMem | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					swap="$(sysctl -n vm.swapusage)"
					procs="$(echo "$top" | grep 'Processes' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					net="$(echo "$top" | grep 'Networks' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
					disk="$(echo "$top" | grep 'Disks' | sed 's/^[^:]*:[[:space:]]\{1,\}//')"
				;;
			esac
			tabMin='\t\t'
			tabMax='\t\t\t'
			#--linux
			if command -v 'hostnamectl' > /dev/null; then
				hostnamectl "$@"
			#--termux
			elif command -v 'termux-info' > /dev/null; then
				termux-info "$@"
				tabMin='\t'
				tabMax='\t'
			#--mac
			elif command -v 'sw_vers' > /dev/null; then
				sw_vers "$@"
				# echo "$hi"
				# echo "-------"
				# echo "$top"
				#-!super verbose and slow. do we want this?
				# if [ -z "$*" ]; then
					# set -- '-detailLevel' 'mini'
				# fi
				# system_profiler "$@" | less
			fi
			if [ -n "$cpu" ]; then
				printf "CPU:$tabMax%s\n" "$cpu"
			fi
			printf "Uptime:$tabMax%s users\n" "$(echo "$uptime" | sed 's/^.*up[[:space:]]\{1,\}//' | sed 's/ user.*$//' | sed 's/  / /g')"
			printf "CPU usage:$tabMin%s\n" "$cpuUsage"
			printf "Load:$tabMax%s\n" "$load"
			printf "Memory:$tabMax%s\n" "$mem"
			if [ -n "$memUsed" ]; then
				printf "Mem Used:$tabMin%s\n" "$memUsed"
			fi
			printf "Swap:$tabMax%s\n" "$swap"
			printf "Procs:$tabMax%s\n" "$procs"
			if [ -n "$net" ]; then
				printf "Networks:$tabMin%s\n" "$net"
			fi
			if [ -n "$disk" ]; then
				printf "Disks:$tabMax%s\n" "$disk"
			fi
			printf "WM:$tabMax%s\n" "$(getwm)"
		else
			set -- 'info' "$@"
			runPkg "$@"
		fi
	;;
	'list'|'l') #: list OS packages
		set -- 'list' "$@"
		runPkg "$@"
	;;
	'lock'|'lockscreen') #: lock screen
		#--gnome
		if [ "$(getwm)" = 'gnome' ] && command -v 'xdg-screensaver' > /dev/null; then
			xdg-screensaver lock
		#--i3
		elif [ "$(getwm)" = 'i3' ] && command -v 'i3lock' > /dev/null; then
			i3lock "$@"
		#--mac
		elif command -v 'pmset' > /dev/null; then
			set -- 'displaysleepnow' "$@"
			pmset "$@"
		else
			die "don't know how to lock"
		fi
	;;
	'logout'|'out') #: log out
		goodbye
		#--gnome
		if [ "$(getwm)" = 'gnome' ] && command -v 'gnome-session-quit' > /dev/null; then
			if [ -z "$*" ]; then
				set -- '--no-prompt'
			fi
			gnome-session-quit "$@"
		#--i3
		elif [ "$(getwm)" = 'i3' ] && command -v 'i3-msg' > /dev/null; then
			set -- 'exit' "$@"
			i3-msg "$@"
		#--mac
		elif command -v 'osascript' > /dev/null; then
			osascript -e 'tell application "System Events" to log out'
			# launchctl bootout user/$(id -u)
		else
			logout
		fi
	;;
	'p'|'package'|'packages'|'pkg') #: run package manager command
		runPkg "$@"
	;;
	're'|'reboot'|'restart') #: reboot computer / OS
		echo 'Til we meet again'
		sleep 3
		if command -v 'reboot' > /dev/null; then
			reboot "$@"
		else
			die "don't know how to reboot"
		fi
	;;
	'remove'|'rm'|'uninstall') #: uninstall OS package
		set -- 'remove' "$@"
		runPkg "$@"
	;;
	's'|'search') #: search for OS packages
		set -- 'search' "$@"
		runPkg "$@"
	;;
	'up'|'update'|'upgrade') #: upgrade OS packages
		set -- 'up' "$@"
		runPkg "$@"
	;;
	*)
		die "Unknown os command ${cmd} command"
	;;
esac

