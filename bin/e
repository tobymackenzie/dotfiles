#!/bin/sh
# shellcheck disable=SC3044
(shopt -s expand_aliases 2> /dev/null) && shopt -s expand_aliases
#--edit: edit argument(s) in `vi`. If passed a command, will run that command and pipe to `vi`.  Otherwise, pass as arguments to `vi`.
editor="${VISUAL:-${EDITOR:-vi}}"
if [ -s /dev/stdin ]; then
	usingStdin=1
else
	usingStdin=0
fi
if [ ! -e "$1" ] && ([ -x "$(command -v "$1")" ] || type "$1" >/dev/null 2>&1); then
	useCmd=1
else
	useCmd=0
fi
if [ "$usingStdin" = 1 ] || [ "$useCmd" = 1 ]; then
	dashOpt=''
	ro=''
	case "$editor" in
		vi|vim|gvim|mvim)
			addDash=1
			for opt in "$@"; do
				if [ "$opt" = '-' ]; then
					addDash=0
				fi
			done
			if [ "$addDash" = 1 ]; then
				dashOpt='-'
			fi
			ro='-R'
		;;
	esac
	if [ "$usingStdin" = 1 ]; then
		set -- "$ro" "$@" "$dashOpt"
		$editor "$@"
	else
		cmd="$1"
		shift
		args="$*"
		set -- "$ro" "$dashOpt"
		echo "$cmd \"$args\" | $editor \"$*\""
		if [ -n "$args" ]; then
			# shellcheck disable=SC2086
			$cmd $args | $editor "$@"
		else
			$cmd | $editor "$@"
		fi
	fi
else
	$editor "$@"
fi
