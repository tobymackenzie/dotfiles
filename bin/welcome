#!/bin/sh
tputColors="$(tput colors 2> /dev/null || echo 2)"
if [ "$tputColors" -gt 2 ]; then
	if [ "$tputColors" -gt 8 ]; then
		tput setaf 42
	else
		tput setaf 2
	fi
fi
hello
cat "$TJM_DOTFILES_PATH/shells/welcome.txt"
if [ -z "$HOST" ]; then
	HOST="$(hostname)"
fi
printf "%s %s\n" "$HOST" "$(uptime | sed 's/^[ 0-9:]*//')"
out="Welcome"
if [ -n "$1" ]; then
	out="$out to $1"
fi
if [ -n "$TJM_OS" ]; then
	out="$out on $TJM_OS"
fi
echo "$out"
if [ "$tputColors" -gt 2 ]; then
	tput sgr0
fi
